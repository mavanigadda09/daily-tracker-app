{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*":           ["./src/*"],
      "@hooks/*":      ["./src/hooks/*"],
      "@context/*":    ["./src/context/*"],
      "@components/*": ["./src/components/*"],
      "@pages/*":      ["./src/pages/*"],
      "@utils/*":      ["./src/utils/*"],
      "@firebase/*":   ["./src/firebase/*"],
      "@assets/*":     ["./src/assets/*"],
      "@styles/*":     ["./src/styles/*"]
    },
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "checkJs": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}